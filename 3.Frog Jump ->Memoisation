li f(li ind,vec &v,vec &dp){
    if(ind==0)return dp[ind]=0;
    if(dp[ind]!=-1)return dp[ind];
    
    li left=f(ind-1,v,dp)+abs(v[ind]-v[ind-1]);
    li right=X;
    if(ind>1)right=f(ind-2,v,dp)+abs(v[ind]-v[ind-2]);
    return dp[ind]=min(left,right);

}

